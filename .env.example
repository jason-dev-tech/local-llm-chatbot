# ==============================
# OpenAI-Compatible Endpoint Configuration
# ==============================

# Local development example:
# OPENAI_BASE_URL=http://localhost:1234/v1
#
# Docker Desktop example:
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
#
# Generic hosted OpenAI-compatible example:
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example.com/v1
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=your-api-key
MODEL_NAME=your-chat-model-name
EMBEDDING_MODEL=your-embedding-model-name


# ==============================
# Storage Configuration
# ==============================

DB_PATH=data/chat_store.db
KNOWLEDGE_DIR=knowledge
CHROMA_PERSIST_DIR=data/chroma_db
RAG_COLLECTION_NAME=knowledge_base
JSON_API_MANIFEST_PATH=knowledge/api_sources.json


# ==============================
# Retrieval Chunking
# ==============================

CHUNK_SIZE=500
CHUNK_OVERLAP=100


# ==============================
# Session Configuration
# ==============================

SESSION_ID=default
